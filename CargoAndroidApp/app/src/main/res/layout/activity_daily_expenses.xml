<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="16dp"
            android:paddingTop="16dp"
            android:paddingRight="16dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_icon_button"
                android:contentDescription="@string/back"
                android:padding="10dp"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/section_title" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/daily_expenses"
                    android:textColor="@color/section_title"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/daily_expenses_subtitle"
                    android:textColor="@color/section_hint"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:id="@+id/contentScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/card_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:hint="@string/filter_month"
                                app:boxCornerRadiusBottomEnd="18dp"
                                app:boxCornerRadiusBottomStart="18dp"
                                app:boxCornerRadiusTopEnd="18dp"
                                app:boxCornerRadiusTopStart="18dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/monthFilterInput"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/loadMonthButton"
                                android:layout_width="0dp"
                                android:layout_height="56dp"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="@string/load_history"
                                android:textAllCaps="false"
                                app:backgroundTint="@color/button_secondary_bg"
                                app:cornerRadius="18dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_history_metric_chip"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/total_expenses"
                                    android:textColor="@color/history_subtitle"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/totalExpenseValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="Rs 0"
                                    android:textColor="@color/section_title"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_history_metric_chip"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/total_days"
                                    android:textColor="@color/history_subtitle"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/totalDaysValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="0"
                                    android:textColor="@color/section_title"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/card_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/add_update_daily_expense"
                            android:textColor="@color/section_title"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:hint="@string/expense_date"
                            app:boxCornerRadiusBottomEnd="18dp"
                            app:boxCornerRadiusBottomStart="18dp"
                            app:boxCornerRadiusTopEnd="18dp"
                            app:boxCornerRadiusTopStart="18dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/expenseDateInput"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:hint="@string/cargo_service_cost"
                                app:boxCornerRadiusBottomEnd="18dp"
                                app:boxCornerRadiusBottomStart="18dp"
                                app:boxCornerRadiusTopEnd="18dp"
                                app:boxCornerRadiusTopStart="18dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/cargoServiceCostInput"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="numberDecimal" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:hint="@string/mobile_cost"
                                app:boxCornerRadiusBottomEnd="18dp"
                                app:boxCornerRadiusBottomStart="18dp"
                                app:boxCornerRadiusTopEnd="18dp"
                                app:boxCornerRadiusTopStart="18dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/mobileCostInput"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="numberDecimal" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:hint="@string/moboil_change_cost"
                                app:boxCornerRadiusBottomEnd="18dp"
                                app:boxCornerRadiusBottomStart="18dp"
                                app:boxCornerRadiusTopEnd="18dp"
                                app:boxCornerRadiusTopStart="18dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/moboilChangeCostInput"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="numberDecimal" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:hint="@string/mechanic_cost"
                                app:boxCornerRadiusBottomEnd="18dp"
                                app:boxCornerRadiusBottomStart="18dp"
                                app:boxCornerRadiusTopEnd="18dp"
                                app:boxCornerRadiusTopStart="18dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/mechanicCostInput"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="numberDecimal" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:hint="@string/food_cost"
                                app:boxCornerRadiusBottomEnd="18dp"
                                app:boxCornerRadiusBottomStart="18dp"
                                app:boxCornerRadiusTopEnd="18dp"
                                app:boxCornerRadiusTopStart="18dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/foodCostInput"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="numberDecimal" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:hint="@string/security_guard_fee"
                                app:boxCornerRadiusBottomEnd="18dp"
                                app:boxCornerRadiusBottomStart="18dp"
                                app:boxCornerRadiusTopEnd="18dp"
                                app:boxCornerRadiusTopStart="18dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/securityGuardFeeInput"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="numberDecimal" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:hint="@string/other_cost"
                            app:boxCornerRadiusBottomEnd="18dp"
                            app:boxCornerRadiusBottomStart="18dp"
                            app:boxCornerRadiusTopEnd="18dp"
                            app:boxCornerRadiusTopStart="18dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/otherCostInput"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:hint="@string/notes"
                            app:boxCornerRadiusBottomEnd="18dp"
                            app:boxCornerRadiusBottomStart="18dp"
                            app:boxCornerRadiusTopEnd="18dp"
                            app:boxCornerRadiusTopStart="18dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/notesInput"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minLines="3" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/saveExpenseButton"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="16dp"
                            android:text="@string/save_daily_expense"
                            android:textAllCaps="false"
                            app:backgroundTint="@color/button_primary"
                            app:cornerRadius="18dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/daily_expense_history"
                    android:textColor="@color/section_title"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/emptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_history_metric_chip"
                    android:gravity="center"
                    android:padding="18dp"
                    android:text="@string/no_daily_expenses"
                    android:textColor="@color/history_subtitle"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/historyContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3F6F7F9"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:indicatorColor="@color/button_primary"
            app:trackColor="@color/progress_track" />
    </LinearLayout>
</FrameLayout>
